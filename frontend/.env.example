# Copy to .env in this folder (frontend/). Vite only exposes vars prefixed with VITE_.
# Brain API (default in code: http://localhost:8001)
# VITE_API_BASE_URL=http://localhost:8001
# Force browser Web Speech instead of server Whisper upload:
# VITE_FORCE_BROWSER_SPEECH=true
# Whisper model for POST /audio/transcribe (default base)
# VITE_WHISPER_MODEL=base
# Optional stronger model for final audio->English pass (recommended: small/medium)
# VITE_WHISPER_TRANSLATE_MODEL=small
# Optional fixed language hint for Whisper (e.g. te, hi, en)
# VITE_WHISPER_SOURCE_LANGUAGE_HINT=te
